# =============================================================================
# Workbench Environment Variables
# =============================================================================
# Copy this file to .env and fill in your API keys:
#   cp .env.example .env
#
# This file is sourced by both:
#   1. Vite dev server (VITE_* vars → browser)
#   2. start-services.sh (server-side vars → memory server process)
# =============================================================================

# --- Browser-side (Vite) ---------------------------------------------------

# OpenAI API key for browser-side chat completions
# Required for the Chat page to work
VITE_OPENAI_API_KEY=

# OpenAI model to use (default: gpt-4o-mini)
VITE_OPENAI_MODEL=gpt-4o-mini

# --- Server-side (sourced by start-services.sh) -----------------------------

# Same OpenAI key, used by the memory server for embeddings and extraction
OPENAI_API_KEY=

# Redis connection (default: redis://redis:6379 inside devcontainer)
# REDIS_URL=redis://localhost:6379

# Memory extraction settings
EXTRACTION_DEBOUNCE_SECONDS=2
ENABLE_DISCRETE_MEMORY_EXTRACTION=true
